{
    "name": "snowflake-crypto-sink",
    "config": {
        "connector.class": "com.snowflake.kafka.connector.SnowflakeStreamingSinkConnector",
        "tasks.max": "1",
        "topics": "crypto-prices",
        "snowflake.url.name": "lfgvsos-ur44106.snowflakecomputing.com:443",
        "snowflake.user.name": "KAFKA_USER",
        "snowflake.role.name": "KAFKA_CONNECTOR_ROLE",
        "snowflake.warehouse.name": "CRYPTO_WH",
        "snowflake.private.key": "-----BEGIN PRIVATE KEY-----\\n-----END PRIVATE KEY-----\n",
        "snowflake.database.name": "CRYPTO_PIPELINE",
        "snowflake.schema.name": "RAW",
        "snowflake.topic2table.map": "crypto-prices:CRYPTO_PRICES",
        "buffer.count.records": "100",
        "buffer.flush.time": "10",
        "key.converter": "org.apache.kafka.connect.storage.StringConverter",
        "value.converter": "org.apache.kafka.connect.json.JsonConverter",
        "value.converter.schemas.enable": "false",
        "snowflake.streaming.validate.compatibility.with.classic": "false"
    }
}